#!/usr/bin/env sh
npx lint-staged

# Security audit on pre-commit (only for security-sensitive changes)
if git diff --cached --name-only | grep -E "\.(ts|tsx|js|jsx)$" | grep -v node_modules | head -n 1 | xargs -r npm audit --audit-level=moderate > /dev/null 2>&1; then
  echo "✅ Pre-commit security check passed"
else
  echo "⚠️  Security audit found potential vulnerabilities in staged files"
  echo "Run 'npm audit' to see details"
fi
