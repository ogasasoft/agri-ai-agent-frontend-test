# Database Configuration
DATABASE_URL=postgresql://username:password@host:5432/agri_ai_db?sslmode=require

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Management
SESSION_SECRET=your-session-secret-key-change-this-in-production
REMEMBER_TOKEN_SECRET=your-remember-token-secret-key-change-this-in-production

# Yamato Transport API (if implementing shipping features)
YAMATO_API_KEY=your-yamato-api-key
YAMATO_API_SECRET=your-yamato-api-secret
YAMATO_API_BASE_URL=https://api.yamato.co.jp/v1

# Colormi Shop API (if implementing shop integration)
COLORMI_API_KEY=your-colormi-api-key
COLORMI_API_BASE_URL=https://api.colormi.jp

# Tabechoku API (if implementing shop integration)
TABECHOKU_API_KEY=your-tabechoku-api-key
TABECHOKU_API_BASE_URL=https://api.tabechoku.jp

# Environment
NODE_ENV=development

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature Flags (optional)
ENABLE_AI_CHAT=true
ENABLE_SHIPPING=true
ENABLE_SHOP_INTEGRATION=true
