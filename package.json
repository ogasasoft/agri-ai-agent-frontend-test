    "test:watch": "jest --watch",
    "test:ci": "jest --ci --maxWorkers=2 --coverage --coveragePathIgnorePatterns=['<rootDir>/node_modules/'] --coverageReporters='text-summary' --coverageReporters='lcov' --coverageReporters='html'",
