    "react-dropzone": "^14.3.1",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
